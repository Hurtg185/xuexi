---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import * as Icons from 'react-icons/hi'; // 这种引入方式在部署时更稳健

const modules = [
  { title: "AI 背单词", desc: "多邻国式学习", link: "/learn", color: "bg-indigo-500" },
  { title: "分类词库", desc: "HSK 专项突破", link: "/categories", color: "bg-emerald-500" },
  { title: "拼音点读", desc: "点击发音练习", link: "/pinyin", color: "bg-orange-500" },
  { title: "学习统计", desc: "查看进步曲线", link: "/stats", color: "bg-rose-500" }
];
---

<Layout>
  <Header />
  <main class="min-h-screen bg-slate-50 dark:bg-zinc-900 px-6 py-10">
    <h1 class="text-3xl font-black mb-2 dark:text-white">学习中心</h1>
    <p class="text-slate-500 mb-10 text-sm">选择一个模块开始今天的旅程</p>

    <div class="grid grid-cols-2 gap-4">
      {modules.map(mod => (
        <a href={mod.link} class="active:scale-95 transition-all">
          <div class="bg-white dark:bg-zinc-800 p-6 rounded-[2rem] shadow-xl shadow-slate-200/50 dark:shadow-none border border-slate-50 dark:border-zinc-700">
            <div class={`${mod.color} w-10 h-10 rounded-xl mb-4 flex items-center justify-center text-white`}>
              <Icons.HiCollection size={20} />
            </div>
            <h3 class="font-bold text-slate-800 dark:text-zinc-100 text-sm">{mod.title}</h3>
            <p class="text-[10px] text-slate-400 mt-1">{mod.desc}</p>
          </div>
        </a>
      ))}
    </div>

    <div class="mt-12">
       <h2 class="font-bold mb-4 dark:text-white">最近学习</h2>
       <div class="bg-white dark:bg-zinc-800 rounded-2xl p-4 border border-slate-100 dark:border-zinc-700">
          <div class="flex items-center justify-between font-bold text-slate-700 dark:text-zinc-300">
             <span>深造</span>
             <Icons.HiChevronRight />
          </div>
       </div>
    </div>
  </main>
  <Footer />
</Layout>
