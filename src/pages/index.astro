---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { pinyin } from 'pinyin-pro';
import { HiSparkles, HiVolumeUp, HiMicrophone, HiFire, HiChevronRight } from 'react-icons/hi';

// 模拟 HSK 数据
const word = "深造";
const translation = "To pursue advanced studies";
const displayPinyin = pinyin(word, { type: 'tone' });
---

<Layout>
  <Header />
  <main id="main-content" class="min-h-[calc(100vh-150px)] flex flex-col bg-[#FDFDFD] dark:bg-zinc-900 transition-colors">
    
    <section class="px-6 pt-8">
      <div class="bg-indigo-600 rounded-[2rem] p-6 text-white shadow-xl shadow-indigo-100 dark:shadow-none relative overflow-hidden">
        <div class="relative z-10 flex justify-between items-center">
          <div>
            <p class="text-indigo-200 text-xs font-bold uppercase tracking-widest mb-1">HSK Level 5</p>
            <h2 class="text-xl font-black">每日核心词汇</h2>
          </div>
          <div class="flex items-center gap-1 bg-white/20 px-3 py-1 rounded-full backdrop-blur-md">
            <HiFire class="text-orange-400" />
            <span class="text-xs font-bold">12 Days</span>
          </div>
        </div>
        <div class="mt-4 w-full bg-black/10 h-2 rounded-full overflow-hidden border border-white/5">
           <div class="bg-white h-full w-[45%] rounded-full shadow-[0_0_8px_white]"></div>
        </div>
      </div>
    </section>

    <section class="flex-1 px-6 py-8 flex flex-col justify-center items-center">
      <div class="w-full max-w-md bg-white dark:bg-zinc-800 rounded-[3rem] p-10 shadow-[0_30px_60px_-12px_rgba(0,0,0,0.05)] border border-slate-50 dark:border-zinc-700 flex flex-col items-center relative">
        
        <div class="text-indigo-500 dark:text-indigo-400 font-bold tracking-[0.3em] mb-2 uppercase text-lg italic">
          {displayPinyin}
        </div>
        
        <h1 class="text-8xl font-black text-slate-900 dark:text-white mb-8 tracking-tighter">
          {word}
        </h1>

        <div class="w-full bg-slate-50 dark:bg-zinc-700/50 rounded-[2rem] p-6 mb-8 border border-slate-100 dark:border-zinc-700">
          <div class="flex items-center gap-2 text-indigo-600 dark:text-indigo-300 text-[10px] font-black uppercase mb-2">
            <HiSparkles /> <span>AI Insight</span>
          </div>
          <p class="text-xl font-bold text-slate-700 dark:text-zinc-200 leading-tight">
            {translation}
          </p>
        </div>

        <div class="flex gap-4 w-full">
          <button class="flex-1 py-5 bg-white dark:bg-zinc-800 border-b-4 border-slate-200 dark:border-zinc-950 rounded-2xl flex items-center justify-center text-slate-600 dark:text-zinc-400 active:border-b-0 active:translate-y-1 transition-all">
            <HiVolumeUp size={30} />
          </button>
          <button class="flex-1 py-5 bg-rose-500 border-b-4 border-rose-700 rounded-2xl flex items-center justify-center text-white active:border-b-0 active:translate-y-1 transition-all shadow-lg shadow-rose-100 dark:shadow-none">
            <HiMicrophone size={30} />
          </button>
        </div>
      </div>
    </section>

    <section class="px-6 pb-10">
      <button class="w-full py-5 bg-slate-900 dark:bg-indigo-600 text-white rounded-[2rem] font-black text-xl flex items-center justify-center gap-3 shadow-2xl active:scale-95 transition-all">
        下一个单词 <HiChevronRight size={24} />
      </button>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  /* 针对移动端隐藏滚动条，保持 App 感 */
  main::-webkit-scrollbar { display: none; }
  * { -webkit-tap-highlight-color: transparent; }
</style>
